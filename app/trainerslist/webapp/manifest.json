{
  "_version": "1.82.0",
  "sap.app": {
    "id": "com.nbx.trainerslist",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.20.3",
      "toolsId": "dce7b601-3a34-482e-9a22-5004844fc08f"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/cap/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.145.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.nbx.trainerslist.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "appView": {
        "type": "sap.ui.model.json.JSONModel"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.f.routing.Router",
        "controlAggregation": "beginColumnPages",
        "controlId": "layout",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "com.nbx.trainerslist.view",
        "async": true
      },
      "routes": [
        {
          "name": "RouteTrainers",
          "pattern": "",
          "layout": "OneColumn",
          "target": [
            "TargetTrainers"
          ]
        },
        {
          "name": "RouteTeams",
          "pattern": "trainer/{trainerId}",
          "layout": "TwoColumnsMidExpanded",
          "target": [
            "TargetTrainers",
            "TargetTeams"
          ]
        },
        {
          "name": "RouteCaptures",
          "pattern": "trainer/{trainerId}/team/{teamId}",
          "layout": "ThreeColumnsMidExpanded",
          "target": [
            "TargetTrainers",
            "TargetTeams",
            "TargetCaptures"
          ]
        }
      ],
      "targets": {
        "TargetTrainers": {
          "type": "View",
          "name": "Main",
          "Id": "MainID",
          "level": 1,
          "controlAggregation": "beginColumnPages"
        },
        "TargetTeams": {
          "type": "View",
          "name": "Detail",
          "Id": "DetailID",
          "level": 2,
          "controlAggregation": "midColumnPages"
        },
        "TargetCaptures": {
          "type": "View",
          "name": "Captures",
          "Id": "CapturesID",
          "level": 3,
          "controlAggregation": "endColumnPages"
        }
      }
    },
    "rootView": {
      "viewName": "com.nbx.trainerslist.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}