<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <Table items="{Teams}"
           mode="SingleSelectMaster"
           itemPress=".onPressItem">
        <columns>
            <Column>
                <Text text="{i18n>showTeamName}" />
            </Column>
            <Column>
                <Text text="{i18n>showTeamDescription}" />
            </Column>
            <Column>
                <Text text="{i18n>showTeamStatus}" />
            </Column>
        </columns>
        <items>
            <ColumnListItem type="Navigation">
                <cells>
                    <Text text="{Name}" />
                    <Text text="{Description}" />
                    <Text text="{Active}" />
                </cells>
            </ColumnListItem>
        </items>
    </Table>
</core:FragmentDefinition>