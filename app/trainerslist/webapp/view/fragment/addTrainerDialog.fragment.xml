<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form">
    
    <Dialog 
        title="{i18n>titleWizard}"> 
        <content>
            <Wizard showNextButton="false">
                <WizardStep title="{i18n>titleStep}">
                    <form:SimpleForm editable="true" layout="ColumnLayout">
                        <Label text="{i18n>infoFirstName}" required="true"/>
                        <Input value="{newTrainer>/firstName}" />
                        
                        <Label text="{i18n>infoLastName}" required="true"/>
                        <Input value="{newTrainer>/lastName}" />
                        
                        <Label text="{i18n>infoEmail}" required="true"/>
                        <Input value="{newTrainer>/Email}" type="Email" />
                        
                        <Label text="{i18n>infoBirthDate}" required="true"/>
                        <DatePicker value="{newTrainer>/BirthDate}" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" />
                    </form:SimpleForm>
                </WizardStep>

            </Wizard>
        </content>

        <beginButton>
            <Button text="{i18n>addTrainerSaveButton}" type="Accept" press=".onSaveTrainer"/>
        </beginButton>
        <endButton>
            <Button text="{i18n>addTrainerCancelButton}" press=".onCloseWizard"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>