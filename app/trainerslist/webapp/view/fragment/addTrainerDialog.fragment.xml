<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form">
    
    <Dialog 
        title="{i18n>titleWizard}"> 
        <content>
            <Wizard showNextButton="false">
                <WizardStep title="Trainer Information">
                    <form:SimpleForm editable="true" layout="ColumnLayout">
                        <Label text="First Name" required="true"/>
                        <Input value="{newTrainer>/firstName}" />
                        
                        <Label text="Last Name" required="true"/>
                        <Input value="{newTrainer>/lastName}" />
                        
                        <Label text="Email" required="true"/>
                        <Input value="{newTrainer>/Email}" type="Email" />
                        
                        <Label text="Birth Date" required="true"/>
                        <DatePicker value="{newTrainer>/BirthDate}" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" />
                    </form:SimpleForm>
                </WizardStep>

            </Wizard>
        </content>

        <beginButton>
            <Button text="Save" type="Accept" press=".onSaveTrainer"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" press=".onCloseWizard"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>