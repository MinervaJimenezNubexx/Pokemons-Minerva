<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form">
    
    <Dialog 
        id="catchDialog" 
        title="{i18n>captureRandomPokemontitle}">
        
        <content>
            <form:SimpleForm layout="ColumnLayout" editable="true">
                <form:content>
                    <Label text="{i18n>randomPokemonName}"/>
                    <Text text="{randomPokemon>/name}" />
                    
                    <Label text="{i18n>randomPokemonWeight}"/>
                    <Text text="{randomPokemon>/weight} {i18n>randomPokemonWeigthMeasurement}" />
                    
                    <Label text="{i18n>randomPokemonHeigth}"/>
                    <Text text="{randomPokemon>/height} {i18n>randomPokemonHeigthmeasurement}" />

                    <Label text="{i18n>randomPokemonSelectTeamLabel}" required="true"/>
                    <Select id="teamSelector" items="{Teams}">
                        <core:Item key="{ID}" text="{Name}" />
                    </Select>
                </form:content>
            </form:SimpleForm>
        </content>

        <beginButton>
            <Button text="{i18n>captureButton}"
            icon="sap-icon://accept"
            type="Accept"
            press=".onCapturePokemon"/>
        </beginButton>
        <endButton>
            <Button text="{i18n>cancelButton}"
            icon="sap-icon://decline"
            type="Reject"
            press=".onCancelCapture"/>
        </endButton>
        
    </Dialog>
</core:FragmentDefinition>