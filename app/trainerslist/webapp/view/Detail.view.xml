<mvc:View xmlns:form="sap.ui.layout.form" 
    controllerName="com.nbx.trainerslist.controller.Detail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Page id="DetailID" title="{i18n>titleDetail}">

        <ObjectHeader
            title="{firstName} {lastName}"
            number="{ID}"
            numberUnit="ID">

                <ObjectAttribute text="{i18n>showEmail} {Email}" />
                <ObjectAttribute text="{i18n>showBirthDate} {BirthDate}" />

        </ObjectHeader>

        <IconTabBar >
            <items>
                <IconTabFilter text="{i18n>iconTapBarTitle1}">
                    <core:Fragment fragmentName="com.nbx.trainerslist.view.fragment.teamsTable" type="XML"/>
                </IconTabFilter>
            </items>
        </IconTabBar>

        <footer>
            <Toolbar>
                <Button 
                    text="{i18n>catchRandomPokemonButton}" 
                    type="Emphasized" 
                    icon="sap-icon://search"
                    press=".onSearchRandomPokemon" />
                <Button 
                    text="{i18n>addTeamUserButton}" 
                    type="Default" 
                    press=".onOpenAddTeamDialog" />
            </Toolbar>
        </footer>

    </Page>
</mvc:View>