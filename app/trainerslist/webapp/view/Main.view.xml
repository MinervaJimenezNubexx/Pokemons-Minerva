<mvc:View
    controllerName="com.nbx.trainerslist.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
>
    <Page
        id="MainID"
        title="{i18n>MainTitle}"
    >
        <Table
            id="idTrainersTable"
            items="{/Trainers}"
            mode="SingleSelectMaster"
            itemPress=".onPressItem"
        >
            <columns>
                <Column width="5em">
                    <Text text="{i18n>TrainerIdColumn}" />
                </Column>
                <Column width="5em">
                    <Text text="{i18n>FirstNameColumn}" />
                </Column>
                <Column width="5em">
                    <Text text="{i18n>LastNameColumn}" />
                </Column>

            </columns>
            <items>
                <ColumnListItem type="Navigation">
                    <cells>
                        <Text text="{ID}" />
                        <Text text="{firstName}" />
                        <Text text="{lastName}" />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
        <footer>
            <Toolbar>
                <ToolbarSpacer /> 
                <Button 
                    text="{i18n>AddTrainerMainButton}" 
                    type="Default" 
                    press=".onAddDocument" />
                <Button 
                    text="{i18n>AddTeamMainButton}" 
                    type="Default" 
                    press=".onOpenAddTeamDialog" />
            </Toolbar>
        </footer>
    </Page>
</mvc:View>
