<mvc:View controllerName="com.nbx.trainerslist.controller.Captures"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="CapturesID" title="{i18n>titleCaptures}" showNavButton="true" navButtonPress=".onCloseCaptures">
        <Table items="{Captures}">
        <columns>
            <Column>
                <Text text="{i18n>captureIdColumn}" />
            </Column>
            <Column>
                <Text text="{i18n>captureNameColumn}" />
            </Column>
            <Column>
                <Text text="{i18n>captureWeightColumn}" />
            </Column>
            <Column>
                <Text text="{i18n>captureHeightColumn}" />
            </Column>
        </columns>
        <items>
            <ColumnListItem>
                <cells>
                    <Text text="{ID}" />
                    <Text text="{PokemonName}" />
                    <Text text="{Weight}" />
                    <Text text="{Height}" />
                </cells>
            </ColumnListItem>
        </items>
    </Table>

    </Page>
</mvc:View>